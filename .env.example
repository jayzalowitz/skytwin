# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://root@localhost:26257/skytwin?sslmode=disable

# ── Services ─────────────────────────────────────────────────────────
API_PORT=3100
WEB_PORT=3200
WORKER_PORT=3101

# ── IronClaw (optional — leave blank to skip) ───────────────────────
# IRONCLAW_API_URL=http://localhost:4000
# IRONCLAW_WEBHOOK_SECRET=your-webhook-secret

# ── OpenClaw / Ollama (optional — for local LLM reasoning) ──────────
OPENCLAW_API_URL=http://localhost:3456
# OPENCLAW_API_KEY=
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=gemma4:latest
# BRIDGE_PORT=3456

# ── Environment ──────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ── Google OAuth (optional — for real Gmail/Calendar integration) ────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3100/api/oauth/google/callback

# ── Safety limits ────────────────────────────────────────────────────
# DEFAULT_SPEND_LIMIT_PER_ACTION=5000
# DEFAULT_DAILY_SPEND_LIMIT=50000
# APPROVAL_EXPIRY_SECONDS=3600

{
  "name": "skytwin",
  "version": "0.3.2.0",
  "description": "A delegated judgment layer that builds a digital twin of your preferences and acts on your behalf — with safety constraints, explanations, and progressive trust.",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/jayzalowitz/skytwin.git"
  },
  "homepage": "https://github.com/jayzalowitz/skytwin",
  "author": "Jay Zalowitz <jay@skytwin.dev>",
  "license": "Apache-2.0",
  "keywords": [
    "digital-twin",
    "personal-automation",
    "decision-engine",
    "ai-agent",
    "preference-learning",
    "policy-engine",
    "cockroachdb",
    "typescript"
  ],
  "scripts": {
    "start": "./bin/skytwin-dev",
    "stop": "./bin/skytwin-dev --stop",
    "setup": "./bin/skytwin-install",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "db:migrate": "pnpm --filter @skytwin/db migrate",
    "db:seed": "pnpm --filter @skytwin/db seed",
    "desktop": "pnpm --filter @skytwin/desktop start",
    "desktop:dev": "pnpm --filter @skytwin/desktop dev",
    "desktop:build:mac": "pnpm build && pnpm --filter @skytwin/desktop package:mac",
    "desktop:build:win": "pnpm build && pnpm --filter @skytwin/desktop package:win",
    "desktop:build:linux": "pnpm build && pnpm --filter @skytwin/desktop package:linux",
    "desktop:build:all": "pnpm build && pnpm --filter @skytwin/desktop package:all",
    "test:e2e": "./bin/skytwin-e2e-test"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  },
  "packageManager": "pnpm@9.1.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
